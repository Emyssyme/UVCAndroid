<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    tools:context="com.herohan.uvcapp.activity.MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.Usbvideo.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/Theme.Usbvideo.PopupOverlay" />

    </com.google.android.material.appbar.AppBarLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.serenegiant.widget.AspectRatioTextureView
            android:id="@+id/viewMainPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignWithParentIfMissing="true"
            android:layout_centerInParent="true"
            android:visibility="invisible" />

        <!-- quick AWB/AE/AF controls (always visible) -->
        <LinearLayout
            android:id="@+id/internal_camera_quick_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_margin="8dp"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:visibility="gone"
            android:background="#66000000"
            android:padding="4dp">

            <Button
                android:id="@+id/btnQuickAe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AE Auto"
                android:textColor="@color/white"
                android:backgroundTint="#AA000000"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnQuickAwb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AWB Auto"
                android:textColor="@color/white"
                android:backgroundTint="#AA000000"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnQuickAf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AF Auto"
                android:textColor="@color/white"
                android:backgroundTint="#AA000000" />
        </LinearLayout>

        <!-- tap-to-focus marker -->
        <View
            android:id="@+id/tap_focus_marker"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:layout_margin="0dp"
            android:visibility="gone"
            android:background="@drawable/tap_focus_marker" />

        <!-- tally indicator circle -->
        <View
            android:id="@+id/tally_indicator"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="8dp"
            android:background="@drawable/tally_circle" />

        <TextView
            android:id="@+id/tvConnectUSBCameraTip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/main_connect_usb_tip"
            android:textColor="@color/white"
            android:textSize="20dp" />

        <TextView
            android:id="@+id/tvStreamStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:layout_margin="8dp"
            android:text="@string/stream_status_inactive"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="#55000000"
            android:padding="6dp" />

        <TextView
            android:id="@+id/tvVideoRecordTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:drawableLeft="@drawable/ic_record_red_dot"
            android:drawablePadding="5dp"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:visibility="gone"
            tools:text="99:99:99" />

        <LinearLayout
            android:id="@+id/internal_camera_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_margin="8dp"
            android:background="#66000000"
            android:orientation="vertical"
            android:padding="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvInternalCameraControlsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Internal Camera Controls"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvInternalZoomValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zoom: 1.0x"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:layout_marginTop="6dp" />

            <SeekBar
                android:id="@+id/seekbarInternalZoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvInternalExposureMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AE: Auto"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvInternalExposureValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EV: 0"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <SeekBar
                android:id="@+id/seekbarInternalExposure"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvInternalKelvinValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kelvin: 4500K"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <SeekBar
                android:id="@+id/seekbarInternalKelvin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvInternalFocusValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Focus: infinity"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

            <SeekBar
                android:id="@+id/seekbarInternalFocus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvInternalIsoValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ISO: 100"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

            <SeekBar
                android:id="@+id/seekbarInternalIso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvInternalExposureTimeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shutter: 1/100"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

            <SeekBar
                android:id="@+id/seekbarInternalExposureTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnInternalExposureLock"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Exposure Lock"
                    android:textColor="@color/white"
                    android:backgroundTint="#AA000000" />

                <Button
                    android:id="@+id/btnInternalFocusLock"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="1dp"
                    android:text="Focus Lock"
                    android:textColor="@color/white"
                    android:backgroundTint="#AA000000" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnInternalAeToggle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="AE Auto"
                    android:textColor="@color/white"
                    android:backgroundTint="#AA000000" />

                <Button
                    android:id="@+id/btnInternalAwbToggle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="1dp"
                    android:text="AWB Auto"
                    android:textColor="@color/white"
                    android:backgroundTint="#AA000000" />

                <Button
                    android:id="@+id/btnInternalAfToggle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="AF Auto"
                    android:textColor="@color/white"
                    android:backgroundTint="#AA000000" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/internal_camera_bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_margin="8dp"
            android:background="#66000000"
            android:orientation="horizontal"
            android:padding="4dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnBottomSelectCamera"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:text="CAM"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:includeFontPadding="false"
                android:backgroundTint="#55000000"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="4dp" />

            <Button
                android:id="@+id/btnBottomExposure"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:text="EV"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:includeFontPadding="false"
                android:backgroundTint="#55000000"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="4dp" />

            <Button
                android:id="@+id/btnBottomExposureLock"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:text="EV-L"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:includeFontPadding="false"
                android:backgroundTint="#55000000"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="4dp" />

            <Button
                android:id="@+id/btnBottomAfMode"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:text="AF"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:includeFontPadding="false"
                android:backgroundTint="#55000000"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="4dp" />

            <Button
                android:id="@+id/btnBottomFocusLock"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:text="AF-L"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:includeFontPadding="false"
                android:backgroundTint="#55000000"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="4dp" />

            <Button
                android:id="@+id/btnBottomFlash"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:text="FL"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:includeFontPadding="false"
                android:backgroundTint="#55000000"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="4dp" />

            <Button
                android:id="@+id/btnBottomWhiteBalance"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="WB"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:includeFontPadding="false"
                android:backgroundTint="#55000000"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="4dp" />
        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabVideo"
            style="@style/MainFloatingActionButton"
            android:layout_above="@id/fabPicture"
            android:layout_alignParentRight="true"
            android:layout_marginEnd="@dimen/fab_margin"
            android:layout_marginBottom="16dp"
            android:visibility="invisible"
            app:srcCompat="@drawable/ic_switch_video" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabPicture"
            style="@style/MainFloatingActionButton"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"
            android:layout_marginEnd="@dimen/fab_margin"
            android:layout_marginBottom="16dp"
            android:visibility="invisible"
            app:srcCompat="@drawable/ic_switch_camera" />
    </RelativeLayout>
</LinearLayout>